# ─────────────────────────────────────────────────────────────────────────────
# PRAJNA Intelligence Layer — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO
APP_VERSION=1.0.0

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
WORKERS=1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── SLM Provider ──────────────────────────────────────────────────────────────
# Options: mock | ollama | huggingface | openai_compatible
SLM_PROVIDER=mock

# --- Ollama (recommended for local dev) ---
# Start Ollama: ollama serve
# Pull a model: ollama pull mistral:7b-instruct
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct
OLLAMA_TIMEOUT=120

# --- HuggingFace (local GPU/CPU inference) ---
# HF_MODEL_ID=microsoft/phi-3-mini-4k-instruct
# HF_DEVICE=cpu                  # cpu | cuda | mps
# HF_LOAD_IN_4BIT=false
# HF_ADAPTER_PATH=               # path to LoRA adapter (optional)

# --- OpenAI-compatible (cloud or local vLLM/LM Studio) ---
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-3.5-turbo
# OPENAI_TIMEOUT=60

# SLM generation parameters
SLM_MAX_TOKENS=1024
SLM_TEMPERATURE=0.2
SLM_TOP_P=0.9

# ── Prediction Adapter ────────────────────────────────────────────────────────
# local: import PRAJNA engine directly | http: call PRAJNA REST API
PREDICTION_ADAPTER_MODE=local
PREDICTION_ENGINE_URL=http://localhost:8000
PREDICTION_CACHE_TTL_SEC=3600

# ── RAG / Vector Store ────────────────────────────────────────────────────────
RAG_ENABLED=true
CHROMA_HOST=localhost
CHROMA_PORT=8002
CHROMA_COLLECTION=prajna_intelligence
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
RAG_TOP_K=5
RAG_MIN_RELEVANCE=0.35

# ── Data Paths ────────────────────────────────────────────────────────────────
# DATA_ROOT=/path/to/exam-predictor/data
# STUDENT_DATA_DIR=/path/to/exam-predictor/data/student_data

# ── Cache / Redis (optional) ──────────────────────────────────────────────────
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
INSIGHT_CACHE_TTL_SEC=1800

# ── API Limits ────────────────────────────────────────────────────────────────
MAX_TOP_N=50
REQUEST_TIMEOUT_SEC=90
